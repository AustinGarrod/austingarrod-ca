{
  "name": "austingarrod-ca",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro check && astro build",
    "check": "astro check",
    "preview": "astro preview --host 0.0.0.0",
    "generate:assets": "python scripts/generate-assets.py",
    "write:deployment-manifest": "python scripts/write-deployment-manifest.py",
    "verify:dist": "python scripts/verify-build.py",
    "build:deploy": "npm run generate:assets && npm run build && npm run write:deployment-manifest && npm run verify:dist"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@lucide/astro": "^1.23.0",
    "astro": "^7.0.7",
    "typescript": "^6.0.3"
  }
}
