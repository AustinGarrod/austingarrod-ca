---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import "@styles/global.css";
import { profile } from "@data/profile";
import { createBaseJsonLdGraph, type JsonLd, type SchemaPageType } from "@data/seo";

interface Props {
  title?: string;
  description?: string;
  active?: "home" | "about" | "projects" | "contact";
  noIndex?: boolean;
  schemaType?: SchemaPageType;
  breadcrumbLabel?: string;
  mainEntityId?: string;
  structuredData?: JsonLd | JsonLd[];
}

const defaultSchemaType: SchemaPageType = Astro.url.pathname === "/" ? "ProfilePage" : "WebPage";
const {
  title = `${profile.name} | ${profile.title}`,
  description = profile.seoDescription,
  active,
  noIndex = false,
  schemaType = defaultSchemaType,
  breadcrumbLabel,
  mainEntityId,
  structuredData
} = Astro.props;

const canonical = new URL(Astro.url.pathname, "https://austingarrod.ca").toString();
const ogImage = new URL("/og-image.png", "https://austingarrod.ca").toString();
const structuredDataItems = structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [];
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    ...createBaseJsonLdGraph({
      canonical,
      pathname: Astro.url.pathname,
      title,
      description,
      schemaType,
      breadcrumbLabel,
      mainEntityId
    }),
    ...structuredDataItems
  ]
}).replace(/</g, "\\u003c");
const analyticsEnabled = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f8f9ff" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${profile.name} - ${profile.title}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:site_name" content={profile.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${profile.name} - ${profile.title}`} />
    <script type="application/ld+json" set:html={jsonLd} is:inline></script>
    {analyticsEnabled && (
      <script
        defer
        src="https://analytics.garrod.house/script.js"
        data-website-id="bad8bf39-f9e4-4e54-865c-f3438804a9b5"
        data-domains="austingarrod.ca,www.austingarrod.ca"
        data-performance="true"
        data-do-not-track="true"
        is:inline
      ></script>
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header active={active} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
