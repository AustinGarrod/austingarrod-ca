---
import { BriefcaseBusiness, CodeXml, Mail } from "@lucide/astro";
import { profile } from "@data/profile";
---

<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <p class="footer-kicker">Austin Garrod</p>
      <p class="footer-copy">Senior full-stack developer in Ontario, building maintainable products from interface to infrastructure.</p>
    </div>
    <nav class="footer-links" aria-label="Footer links">
      <a href={profile.github} rel="noreferrer" target="_blank">
        <CodeXml size={18} aria-hidden="true" />
        GitHub
      </a>
      <a href={profile.linkedin} rel="noreferrer" target="_blank">
        <BriefcaseBusiness size={18} aria-hidden="true" />
        LinkedIn
      </a>
      <a href={`mailto:${profile.email}`}>
        <Mail size={18} aria-hidden="true" />
        Email
      </a>
    </nav>
  </div>
</footer>
