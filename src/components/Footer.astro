---
import { BriefcaseBusiness, CodeXml, Mail } from "@lucide/astro";
import { profile } from "@data/profile";
---

<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <p class="footer-kicker">Copyright 2026 Austin Garrod</p>
      <p class="footer-copy">Senior full-stack developer in Ontario, building maintainable products from interface to infrastructure.</p>
    </div>
    <nav class="footer-links" aria-label="Footer links">
      <a
        href={profile.github}
        rel="noreferrer"
        target="_blank"
        data-umami-event="outbound-link-click"
        data-umami-event-destination="github"
        data-umami-event-placement="footer"
        data-umami-event-url={profile.github}
      >
        <CodeXml size={18} aria-hidden="true" />
        GitHub
      </a>
      <a
        href={profile.linkedin}
        rel="noreferrer"
        target="_blank"
        data-umami-event="outbound-link-click"
        data-umami-event-destination="linkedin"
        data-umami-event-placement="footer"
        data-umami-event-url={profile.linkedin}
      >
        <BriefcaseBusiness size={18} aria-hidden="true" />
        LinkedIn
      </a>
      <a
        href={`mailto:${profile.email}`}
        data-umami-event="contact-link-click"
        data-umami-event-method="email"
        data-umami-event-placement="footer"
      >
        <Mail size={18} aria-hidden="true" />
        Email
      </a>
    </nav>
  </div>
</footer>
