---
import { Download, ExternalLink } from "@lucide/astro";
import ExperienceTimeline from "@components/ExperienceTimeline.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { profile, skills } from "@data/profile";
---

<BaseLayout
  active="about"
  title={`About ${profile.name} | ${profile.title}`}
  description="About Austin Garrod, a senior full-stack developer in Ontario with experience across React, Next.js, APIs, databases, teaching, and civic technology."
  schemaType="ProfilePage"
  breadcrumbLabel="About Austin Garrod"
>
  <section class="page-hero">
    <div class="container page-hero-inner">
      <p class="eyebrow">Works / experience</p>
      <h1>About Austin Garrod</h1>
      <p>
        My career has moved through research, freelance delivery, post-secondary teaching, lead development, and senior full-stack engineering. The common thread is practical software built with enough structure that someone else can understand it later.
      </p>
      <div class="button-row">
        <a
          class="button secondary"
          href={profile.resume}
          rel="noreferrer"
          target="_blank"
          data-umami-event="resume-view"
          data-umami-event-placement="about-hero"
        >
          View resume
          <ExternalLink size={18} aria-hidden="true" />
        </a>
        <a
          class="text-link resume-download-link"
          href={profile.resume}
          download="Austin-Garrod-Resume.pdf"
          data-umami-event="file-download"
          data-umami-event-file="austin-garrod-resume.pdf"
          data-umami-event-placement="about-hero"
        >
          Download PDF
          <Download size={16} aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <section class="container content-section">
    <div class="section-heading">
      <p class="eyebrow">Timeline</p>
      <h2>Professional work, teaching, and applied systems.</h2>
    </div>
    <ExperienceTimeline />
  </section>

  <section class="section-band">
    <div class="container content-section tight">
      <div class="section-heading">
        <p class="eyebrow">Technical range</p>
        <h2>Enough breadth to connect the system, enough discipline to keep it simple.</h2>
      </div>
      <div class="skills-grid">
        {skills.map((skill) => (
          <article class="skill-panel">
            <h3>{skill.title}</h3>
            <p>{skill.summary}</p>
            <div class="tag-list">
              {skill.items.map((item) => <span>{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container content-section two-column">
    <div>
      <p class="eyebrow">Education</p>
      <h2>Durham College</h2>
      <p>Diploma, Computer Programming/Programmer, General, 2016-2017. The program foundation maps to the work I still use daily: programming logic, object-oriented development, databases, networking, web development, testing, systems development, and communication.</p>
    </div>
    <div>
      <p class="eyebrow">Teaching foundation</p>
      <h2>Teaching software development</h2>
      <p>Returning to Durham as a professor kept those fundamentals close: problem decomposition, debugging, JavaScript and web standards, Windows application development, project planning, SDLC habits, and the kind of plain-language explanation that makes technical work easier to share.</p>
    </div>
  </section>
</BaseLayout>
