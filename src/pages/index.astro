---
import { ArrowRight, Download, MonitorSmartphone, ShieldCheck, SquareTerminal } from "@lucide/astro";
import ProjectCard from "@components/ProjectCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { highlights, profile, projects, skills } from "@data/profile";

const featuredProjectSlugs = ["honour-our-veterans-banner-platform", "cadence", "spools"];
const featuredProjects = featuredProjectSlugs
  .map((slug) => projects.find((project) => project.slug === slug))
  .filter((project): project is (typeof projects)[number] => Boolean(project));
const coreTech = ["TypeScript", "React", "Next.js", "Node.js", "MongoDB", "Docker"];
---

<BaseLayout active="home">
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Senior full-stack engineering</p>
        <h1>
          <span>{profile.name}</span>
          {" "}
          <span>{profile.title}</span>
        </h1>
        <p class="hero-summary">{profile.tagline}</p>
        <p class="hero-body">{profile.intro}</p>
        <div class="button-row">
          <a class="button primary" href="/projects/">
            View work
            <ArrowRight size={18} aria-hidden="true" />
          </a>
          <a class="button secondary" href={profile.resume} rel="noreferrer" target="_blank">
            View resume
            <Download size={18} aria-hidden="true" />
          </a>
          <a class="text-link resume-download-link" href={profile.resume} download="Austin-Garrod-Resume.pdf">
            Download PDF
            <Download size={16} aria-hidden="true" />
          </a>
        </div>
        <div class="hero-tech" aria-label="Core technologies">
          <span>Core tech</span>
          <div class="tag-list">
            {coreTech.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-band">
    <div class="container metrics-grid">
      {highlights.map((item) => (
        <article class="metric">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container content-section home-profile-section">
    <div class="section-heading">
      <p class="eyebrow">Engineering profile</p>
      <h2>Full-stack product work across interfaces, APIs, data, and delivery.</h2>
      <p>At Epilogue, I own charity-partner product and data systems across React and TypeScript interfaces, Node.js and Express services, MongoDB, analytics, and scheduled AWS reporting. I work directly with leadership to turn large operational datasets into appropriately scoped tools for partners and internal teams.</p>
    </div>
    <div class="skills-grid">
      {skills.map((skill, index) => {
        const icons = [MonitorSmartphone, SquareTerminal, ShieldCheck, ArrowRight];
        const Icon = icons[index] ?? ArrowRight;
        return (
          <article class="skill-panel">
            <Icon size={24} aria-hidden="true" />
            <h3>{skill.title}</h3>
            <p>{skill.summary}</p>
            <div class="tag-list">
              {skill.items.map((item) => <span>{item}</span>)}
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="container content-section selected-work-section">
    <div class="section-heading split">
      <div>
        <p class="eyebrow">Selected work</p>
        <h2>Public evidence and sanitized private case studies.</h2>
      </div>
      <a class="button secondary" href="/projects/">
        All projects
        <ArrowRight size={18} aria-hidden="true" />
      </a>
    </div>
    <div class="project-grid">
      {featuredProjects.map((project, index) => <ProjectCard project={project} featured={index === 0} />)}
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <div>
        <p class="eyebrow">Engineering opportunities</p>
        <h2>Hiring for a senior full-stack role?</h2>
        <p>{profile.availability}. I am interested in product engineering across React, Next.js, TypeScript, Node.js, APIs, and data systems.</p>
      </div>
      <a class="button primary" href="/contact/">
        Start a conversation
        <ArrowRight size={18} aria-hidden="true" />
      </a>
    </div>
  </section>
</BaseLayout>
