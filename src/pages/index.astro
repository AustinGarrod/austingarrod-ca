---
import { ArrowRight, Download, MonitorSmartphone, ShieldCheck, SquareTerminal } from "@lucide/astro";
import ProjectCard from "@components/ProjectCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { highlights, profile, projects, skills } from "@data/profile";

const featuredProjects = projects.slice(0, 3);
const coreTech = ["TypeScript", "React", "Next.js", "Node.js", "MongoDB", "Docker"];
---

<BaseLayout active="home">
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Systems architecture & engineering</p>
        <h1>
          <span>{profile.name}</span>
          <span>{profile.title}</span>
        </h1>
        <p class="hero-summary">{profile.tagline}</p>
        <p class="hero-body">{profile.intro}</p>
        <div class="button-row">
          <a class="button primary" href="/projects/">
            View work
            <ArrowRight size={18} aria-hidden="true" />
          </a>
          <a class="button secondary" href={profile.resume}>
            Download resume
            <Download size={18} aria-hidden="true" />
          </a>
        </div>
        <div class="hero-tech" aria-label="Core technologies">
          <span>Core tech</span>
          <div class="tag-list">
            {coreTech.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-band">
    <div class="container metrics-grid">
      {highlights.map((item) => (
        <article class="metric">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container content-section">
    <div class="section-heading">
      <p class="eyebrow">Engineering profile</p>
      <h2>Calm systems, clear interfaces, practical delivery.</h2>
      <p>{profile.intro}</p>
    </div>
    <div class="skills-grid">
      {skills.map((skill, index) => {
        const icons = [MonitorSmartphone, SquareTerminal, ShieldCheck, ArrowRight];
        const Icon = icons[index] ?? ArrowRight;
        return (
          <article class="skill-panel">
            <Icon size={24} aria-hidden="true" />
            <h3>{skill.title}</h3>
            <p>{skill.summary}</p>
            <div class="tag-list">
              {skill.items.map((item) => <span>{item}</span>)}
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="container content-section">
    <div class="section-heading split">
      <div>
        <p class="eyebrow">Selected work</p>
        <h2>Sanitized case studies from public and private projects.</h2>
      </div>
      <a class="button secondary" href="/projects/">
        All projects
        <ArrowRight size={18} aria-hidden="true" />
      </a>
    </div>
    <div class="project-grid">
      {featuredProjects.map((project, index) => <ProjectCard project={project} featured={index === 0} />)}
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <div>
        <p class="eyebrow">Next conversation</p>
        <h2>Good software is easier to trust when its structure is visible.</h2>
        <p>That is the through-line here: a preference for systems that are understandable, observable, and built for the people who need to keep using them.</p>
      </div>
      <a class="button primary" href="/contact/">
        Contact Austin
        <ArrowRight size={18} aria-hidden="true" />
      </a>
    </div>
  </section>
</BaseLayout>
