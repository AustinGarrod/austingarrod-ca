---
import { BriefcaseBusiness, CodeXml, Mail, Send } from "@lucide/astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { profile } from "@data/profile";
---

<BaseLayout
  active="contact"
  title={`Contact | ${profile.name}`}
  description="Contact Austin Garrod, a senior full-stack developer in Ontario, for thoughtful engineering roles, collaborations, and technical conversations."
  schemaType="ContactPage"
  breadcrumbLabel="Contact Austin Garrod"
>
  <section class="page-hero">
    <div class="container page-hero-inner">
      <p class="eyebrow">Engineering opportunities</p>
      <h1>Hiring a senior full-stack engineer?</h1>
      <p>
        Send the role, team context, location or remote expectations, and the problem you need the engineer to own. I will reply directly. For other thoughtful engineering conversations, email works too.
      </p>
    </div>
  </section>

  <section class="container contact-layout">
    <form class="contact-form" action="/contact.php" method="post" aria-describedby="required-note">
      <div class="form-status success" data-status="sent" role="status" aria-live="polite" aria-atomic="true" hidden>
        Thanks. Your message was sent.
      </div>
      <div class="form-status error" data-status="error" role="alert" aria-live="assertive" aria-atomic="true" hidden>
        Something was missing or the message could not be sent. Please try again or use email directly.
      </div>
      <div class="form-status error" data-status="invalid" role="alert" aria-live="assertive" aria-atomic="true" hidden>
        Please check the form fields and try again.
      </div>
      <p id="required-note" class="form-note">All fields are required; messages must be at least 20 characters.</p>

      <div class="field-grid">
        <label>
          <span>Name</span>
          <input name="name" type="text" autocomplete="name" required maxlength="120" />
        </label>
        <label>
          <span>Email</span>
          <input name="email" type="email" autocomplete="email" required maxlength="160" />
        </label>
      </div>
      <label>
        <span>Subject</span>
        <input name="subject" type="text" required maxlength="160" />
      </label>
      <label class="honeypot" aria-hidden="true" tabindex="-1">
        <span>Website</span>
        <input name="website" type="text" autocomplete="off" tabindex="-1" />
      </label>
      <label>
        <span>Message</span>
        <textarea name="message" required minlength="20" maxlength="4000" rows="8"></textarea>
      </label>
      <button class="button primary" type="submit">
        Send message
        <Send size={18} aria-hidden="true" />
      </button>
    </form>

    <aside class="contact-aside">
      <div>
        <p class="eyebrow">Direct</p>
        <a
          href={`mailto:${profile.email}`}
          data-umami-event="contact-link-click"
          data-umami-event-method="email"
          data-umami-event-placement="contact-page"
        ><Mail size={18} aria-hidden="true" />{profile.email}</a>
      </div>
      <div>
        <p class="eyebrow">Profiles</p>
        <a
          href={profile.github}
          rel="noreferrer"
          target="_blank"
          data-umami-event="outbound-link-click"
          data-umami-event-destination="github"
          data-umami-event-placement="contact-page"
          data-umami-event-url={profile.github}
        ><CodeXml size={18} aria-hidden="true" />GitHub</a>
        <a
          href={profile.linkedin}
          rel="noreferrer"
          target="_blank"
          data-umami-event="outbound-link-click"
          data-umami-event-destination="linkedin"
          data-umami-event-placement="contact-page"
          data-umami-event-url={profile.linkedin}
        ><BriefcaseBusiness size={18} aria-hidden="true" />LinkedIn</a>
      </div>
      <div>
        <p class="eyebrow">Location</p>
        <p>{profile.location}</p>
      </div>
    </aside>
  </section>

  <script>
    const params = new URLSearchParams(window.location.search);
    const status = params.get("status");
    const allowedStatuses = new Set(["sent", "error", "invalid"]);
    if (status && allowedStatuses.has(status)) {
      document.querySelector<HTMLElement>(`[data-status="${status}"]`)?.removeAttribute("hidden");

      const trackResult = () => window.umami?.track(`contact-form-${status}`, { form: "contact" });
      if (document.readyState === "complete") {
        trackResult();
      } else {
        window.addEventListener("load", trackResult, { once: true });
      }
    }

    document.querySelector<HTMLFormElement>(".contact-form")?.addEventListener("submit", () => {
      window.umami?.track("contact-form-submit", { form: "contact" });
    });
  </script>
</BaseLayout>
