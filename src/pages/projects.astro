---
import ProjectCard from "@components/ProjectCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { profile, projects } from "@data/profile";
import { createProjectsStructuredData, PROJECTS_ITEM_LIST_ID } from "@data/seo";

const projectOrder = new Map([
  ["honour-our-veterans-banner-platform", 0],
  ["cadence", 1],
  ["spools", 2],
  ["charity-data-scraper", 3],
  ["austingarrod-ca", 4],
  ["campaign-static-site", 5],
  ["kids-tv-controller", 6]
]);
const orderedProjects = [...projects].sort(
  (a, b) => (projectOrder.get(a.slug) ?? Number.MAX_SAFE_INTEGER) - (projectOrder.get(b.slug) ?? Number.MAX_SAFE_INTEGER)
);
const projectsStructuredData = createProjectsStructuredData(orderedProjects);
---

<BaseLayout
  active="projects"
  title={`Projects | ${profile.name}`}
  description="Full-stack engineering projects by Austin Garrod in Ontario, covering Astro, React, TypeScript, Node.js, mobile apps, data pipelines, and local systems."
  schemaType="CollectionPage"
  breadcrumbLabel="Projects"
  mainEntityId={PROJECTS_ITEM_LIST_ID}
  structuredData={projectsStructuredData}
>
  <section class="page-hero page-hero-compact">
    <div class="container page-hero-inner">
      <p class="eyebrow">Case studies</p>
      <h1>Full-stack engineering projects</h1>
      <p>
        A cross-section of public, private, civic, and local systems. Private work is described at the architecture level so technical decisions are visible without exposing links, credentials, client details, or private data.
      </p>
    </div>
  </section>

  <section class="container content-section projects-list-section">
    <div class="project-grid all-projects">
      {orderedProjects.map((project, index) => <ProjectCard project={project} featured={index === 0} headingLevel={2} />)}
    </div>
  </section>
</BaseLayout>
